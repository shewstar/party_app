NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Web Push. Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secrets — set these to long random strings.
SUPABASE_WEBHOOK_SECRET=
CRON_SECRET=

# Access gate — soft password to keep randoms out of the party app.
# PARTY_PASSWORD: the shared passphrase you tell guests.
# PARTY_GATE_SECRET: HMAC secret for the cookie. Generate via `openssl rand -hex 32`.
PARTY_PASSWORD=
PARTY_GATE_SECRET=

# Kill switch — set to "false" to short-circuit all push fan-out routes
# (useful while testing). Leave unset or "true" in production.
PUSH_ENABLED=true
